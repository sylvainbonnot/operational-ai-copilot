      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "expr": "retrieval_precision_at_k",
        "legendFormat": "precision@k"
      }]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps"}
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "id": 10,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "Request Rate by Endpoint & Status",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(rag_request_total{status=\"ok\"}[1m])",
          "legendFormat": "{{ endpoint }} ok"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(rag_request_total{status=\"error\"}[1m])",
          "legendFormat": "{{ endpoint }} error"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "s"}
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "id": 11,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "Latency Percentiles (end-to-end)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.50, rate(rag_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, rate(rag_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.99, rate(rag_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 13},
      "id": 101,
      "title": "RAG Quality",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "s"}
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "id": 20,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "Retrieval vs LLM Latency",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, rate(retrieval_latency_seconds_bucket[5m]))",
          "legendFormat": "retrieval p95"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, rate(llm_latency_seconds_bucket[5m]))",
          "legendFormat": "llm p95"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short", "min": 0, "max": 1}
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "id": 21,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "Groundedness & Retrieval Precision Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "groundedness_score",
          "legendFormat": "groundedness"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "retrieval_precision_at_k",
          "legendFormat": "retrieval precision@k"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "hallucination_rate",
          "legendFormat": "hallucination rate"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 22},
      "id": 102,
      "title": "LLM Usage",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"}
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 23},
      "id": 30,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "Token Usage Rate (prompt vs completion)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(tokens_total{token_type=\"prompt\"}[5m])",
          "legendFormat": "prompt tokens/s"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(tokens_total{token_type=\"completion\"}[5m])",
          "legendFormat": "completion tokens/s"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"}
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 23},
      "id": 31,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "Agent Tool Calls",
      "type": "timeseries",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "expr": "rate(agent_tool_calls_total[5m])",
        "legendFormat": "{{ tool_name }}"
      }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["operational-ai", "rag", "llm"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
